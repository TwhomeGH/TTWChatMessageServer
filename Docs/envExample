# .env File參數參考以下

CLIENT_ID=Twitch ClientID 你的AppID
CLIENT_SECRET=Twitch ClientID 你的AppSecrt

SIGN_API=EulerStream API 簽名API

TIKTOK_NAME=你的TikTok 用戶名
SESSION_ID=你的TikTok SessionID
TT_TARGET_IDC=你的TikTok Target IDC



BARK_API=你的Bark API
SOCKET_API=你的Socket API
WEB_API=http://localhost:3001/sendSync
TRANSLATE_API_URL=https://api.mymemory.translated.net/get
TRANSLATE_SOURCE_LANG=en
TRANSLATE_TARGET_LANG=zh-TW
TRANSLATE_DEBUG=false
TRANSLATE_MIN_LENGTH=5

GIFT_TRANSLATE_PREFILL_LIMIT=10

DEBUG_CHILD=false

USER_LIKE_CLEAR_TIMER=60000

# WebAPI是用於WebSocket.js的API地址，默認為http://localhost:3001/sendSync，如果你有修改WebSocket.js中的API地址，請相應修改此處。
# TRANSLATE_API_URL 是禮物名稱翻譯 API，預設使用免費的 MyMemory 介面。
# TRANSLATE_SOURCE_LANG / TRANSLATE_TARGET_LANG 是禮物名稱翻譯的來源與目標語言。

# TRANSLATE_DEBUG 用來檢查翻譯訊息 運行情況用的日誌
# TRANSLATE_MIN_LENGTH 最小翻譯字數要求 預設5個字
# GIFT_TRANSLATE_PREFILL_LIMIT 是啟動時用 giftList 預先補翻譯的最大數量，避免一次打太多免費 API。

# DEBUG_CHILD=false 只有在VSCode偵錯 打斷點時使用 正常保持關閉
# USER_LIKE_CLEAR_TIMER=用戶點讚數清除計時器，單位毫秒，預設60000（1分鐘）。當用戶點讚後，經過這段時間後會清除該用戶的點讚數，以便在聊天室中顯示最新的點讚數。

CONFIG_KEY=你的配置頁面存取密碼設置
