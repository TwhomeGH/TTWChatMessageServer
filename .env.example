# TTWChatMessageServer 環境變數範例
# 複製本檔為 .env 後填入你的設定值
# 完整說明請參閱 Docs/envExample

# ─── TikTok ──────────────────────────────────────────
TIKTOK_NAME=coffeelatte0709

# 三種認證方式擇一
# [A] 完整 Cookie（建議）
TIKTOK_COOKIES=fblo_xxx=yyy; sessionid=xxx; tt-target-idc=alisg; ...
# [B] Session ID（舊版相容）
SESSION_ID=你的TikTok SessionID
TT_TARGET_IDC=alisg
# [C] EulerStream API Key（不用 Cookie，走原始簽名服務）
# SIGN_API_KEY=你的EulerStream API Key

# ─── Twitch ──────────────────────────────────────────
CLIENT_ID=你的Twitch Client ID
CLIENT_SECRET=你的Twitch Client Secret
TWITCH_USER_NAME=你的Twitch頻道名稱

# ─── Kick ────────────────────────────────────────────
KICK_CLIENT_ID=你的Kick Client ID
KICK_CLIENT_SECRET=你的Kick Client Secret
KICK_USER_NAME=你的Kick頻道名稱
KICK_CHANNEL_ID=你的Kick頻道ID

# ─── Odysee ──────────────────────────────────────────
ODYSEE_CHANNEL_NAME=你的Odysee頻道名稱

# ─── Youtube ─────────────────────────────────────────
YOUTUBE_API_KEY=你的YouTube Data API Key
YOUTUBE_CHANNEL_ID=你的YouTube頻道ID

# ─── 推送 ────────────────────────────────────────────
BARK_API=https://api.day.app/你的Bark Key
SOCKET_API=http://192.168.0.101:9322

# ─── 翻譯 ────────────────────────────────────────────
TRANSLATE_API_URL=https://api.mymemory.translated.net/get
TRANSLATE_SOURCE_LANG=en
TRANSLATE_TARGET_LANG=zh-TW
GIFT_TRANSLATE_PREFILL_LIMIT=10
